{
    "default_model": "openrouter/minimax/minimax-m2.7",
    "model_aliases": {
        "nemotron": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "minimax": "openrouter/minimax/minimax-m2.5",
        "minimax-m2.7": "openrouter/minimax/minimax-m2.7",
        "deepseek-v3": "openrouter/deepseek/deepseek-chat-v3-0324",
        "sonnet-4-6": "anthropic/claude-sonnet-4-6",
        "opus-4-6": "anthropic/claude-opus-4-6"
    },
    "providers": {
        "deepseek": {
            "models": {
                "deepseek-chat-v3-0324": {
                    "max_tokens": 16384
                }
            }
        },
        "openrouter": {
            "models": {
                "minimax/minimax-m2.5": {
                    "max_tokens": 65536
                },
                "minimax/minimax-m2.7": {
                    "max_tokens": 131072
                }
            }
        }
    },
    "permission": {
        "*": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "web_search": "allow",
        "web_fetch": "allow",
        "delegate_task": "allow",
        "edit": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        },
        "write": {
            "*": "allow",
            "*.env": "deny"
        },
        "bash": {
            "*": "ask",
            "git *": "allow",
            "gh *": "allow",
            "npm *": "allow",
            "pytest": "allow",
            "pytest *": "allow",
            "python *": "allow",
            "xargs *": "allow",
            ".venv/bin/pytest *": "allow",
            ".venv/Scripts/pytest *": "allow",
            ".venv/Scripts/pytest.exe *": "allow",
            ".venv/Scripts/python *": "allow",
            ".venv/Scripts/python.exe *": "allow",
            ".venv/bin/python *": "allow",
            "uv run pytest *": "allow",
            "uv run python *": "allow"
        }
    }
}