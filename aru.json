{
    "models": {
        "default": "openrouter/deepseek/deepseek-chat-v3-0324",
        "minimax": "openrouter/minimax/minimax-m2.5",
        "deepseek-v3": "openrouter/deepseek/deepseek-chat-v3-0324",
        "sonnet-4-6": "anthropic/claude-sonnet-4-6",
        "opus-4-6": "anthropic/claude-opus-4-6"
    },
    "providers": {
        "deepseek": {
            "models": {
                "deepseek-chat-v3-0324": {"id": "deepseek-chat-v3-0324", "max_tokens": 16384}
            }
        },
        "openrouter": {
            "models": {
                "minimax/minimax-m2.5": {"id": "minimax/minimax-m2.5", "max_tokens": 65536}
            }
        }
    },
    "permission": {
        "allow": [
            "git *",
            "npm *",
            "pytest",
            "pytest *",
            "cd *",
            "find *",
            "xargs *",
            "wc *",
            "tail *",
            "python *",
            ".venv/bin/pytest",
            ".venv/bin/pytest *",
            ".venv/Scripts/pytest",
            ".venv/Scripts/pytest *",
            ".venv/Scripts/pytest.exe",
            ".venv/Scripts/pytest.exe *",
            "uv run pytest",
            "uv run pytest *",
            "uv run python -m pytest",
            "uv run python -m pytest *",
            ".venv/bin/python -m pytest *",
            ".venv/bin/python *",
            ".venv/Scripts/python -m pytest *",
            ".venv/Scripts/python *",
            ".venv/Scripts/python.exe -m pytest *",
            ".venv/Scripts/python.exe *"
        ]
    }
}
